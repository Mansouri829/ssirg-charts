import json
from collections import defaultdict

# =========================
# LOAD SCOPUS PAPER DATA
# =========================
with open("papers.json", "r") as f:
    papers = json.load(f)

# =========================
# AGGREGATE LIKE SCOPUS
# =========================
citations_by_year = defaultdict(int)
docs_by_year = defaultdict(int)

for p in papers:
    year = p["year"]
    citations = p.get("citations", 0)

    citations_by_year[year] += citations
    docs_by_year[year] += 1

years = sorted(citations_by_year.keys())

output = {
    "authorId": "7004271836",
    "years": years,
    "citations": [citations_by_year[y] for y in years],
    "documents": [docs_by_year[y] for y in years]
}

with open("data.json", "w") as f:
    json.dump(output, f, indent=2)

print("✅ data.json rebuilt from Scopus-style data")
